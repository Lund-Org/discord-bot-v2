generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Birthday {
  id            Int    @id @default(autoincrement())
  discordId     String @unique @db.VarChar(255)
  birthdayDay   Int
  birthdayMonth Int
  birthdayYear  Int

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  @@map("Birthday")
}

model BacklogItem {
  id         Int           @id @default(autoincrement())
  userId     Int
  igdbGameId Int
  name       String
  game_type  String
  url        String
  status     BacklogStatus @default(BACKLOG)
  note       String?       @db.VarChar(255)
  order      Int           @default(0)

  startedAt   DateTime? @db.Timestamp(3)
  finishedAt  DateTime? @db.Timestamp(3)
  abandonedAt DateTime? @db.Timestamp(3)
  wishlistAt  DateTime? @db.Timestamp(3)

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  user              User               @relation(fields: [userId], references: [id])
  backlogItemReview BacklogItemReview?

  @@unique([userId, igdbGameId])
  @@index(userId)
  @@map("BacklogItem")
}

model BacklogItemReview {
  id                Int     @id @default(autoincrement())
  backlogItemId     Int     @unique
  rating            Int     @default(0)
  review            String? @db.Text
  duration          Int?
  completion        Int?
  completionComment String? @db.VarChar(255)

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  pros BacklogItemReviewPros[]
  cons BacklogItemReviewCons[]

  backlogItem BacklogItem @relation(fields: [backlogItemId], references: [id], onDelete: Cascade)

  @@map("BacklogItemReview")
}

model BacklogItemReviewPros {
  id                  Int    @id @default(autoincrement())
  backlogItemReviewId Int
  value               String @db.VarChar(255)

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  backlogItemReview BacklogItemReview @relation(fields: [backlogItemReviewId], references: [id])

  @@map("BacklogItemReviewPros")
}

model BacklogItemReviewCons {
  id                  Int    @id @default(autoincrement())
  backlogItemReviewId Int
  value               String @db.VarChar(255)

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  backlogItemReview BacklogItemReview @relation(fields: [backlogItemReviewId], references: [id])

  @@map("BacklogItemReviewCons")
}

model BlogPost {
  id           Int        @id @default(autoincrement())
  filename     String     @unique @db.VarChar(255)
  bannerUrl    String     @db.VarChar(255)
  thumbnailUrl String     @db.VarChar(255)
  category     Category
  state        BlogStatus
  postAt       DateTime
  description  String     @db.Text()
  tags         Tag[]

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  @@map("BlogPost")
}

model CardType {
  id          Int    @id @default(autoincrement())
  name        String @unique @db.VarChar(255)
  description String @db.VarChar(255)
  level       Int
  imageName   String @unique @db.VarChar(255)
  isFusion    Int    @default(0) @db.TinyInt
  lore        String @db.Text

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  possibleFusions    CardType[]             @relation("CardFusions")
  fusionDependencies CardType[]             @relation("CardFusions")
  playerInventory    GachaPlayerInventory[]
  dailyShopItems     GachaDailyShopItem[]

  @@map("CardType")
}

model Config {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(255)
  value Json

  @@map("Config")
}

model GachaDailyPurchase {
  id              Int @id @default(autoincrement())
  playerId        Int
  dailyShopItemId Int

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  dailyShopItem GachaDailyShopItem @relation(fields: [dailyShopItemId], references: [id])
  player        GachaPlayer        @relation(fields: [playerId], references: [id])

  @@unique([playerId, dailyShopItemId])
  @@index([dailyShopItemId])
  @@index([playerId])
  @@map("DailyPurchase")
}

model GachaDailyShop {
  id        Int    @id @default(autoincrement())
  shopDay   Int
  shopMonth Int
  shopYear  Int
  threadId  String

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  dailyShopItems GachaDailyShopItem[]

  @@unique([shopDay, shopMonth, shopYear])
  @@map("GachaDailyShop")
}

model GachaDailyShopItem {
  id          Int    @id @default(autoincrement())
  cardTypeId  Int
  dailyShopId Int
  type        String @db.VarChar(255)
  price       Int

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  cardType      CardType             @relation(fields: [cardTypeId], references: [id])
  dailyShop     GachaDailyShop       @relation(fields: [dailyShopId], references: [id])
  dailyPurchase GachaDailyPurchase[]

  @@unique([cardTypeId, dailyShopId])
  @@index([dailyShopId])
  @@index([cardTypeId])
  @@map("GachaDailyShopItem")
}

model DiscordNotificationChannel {
  id               Int                 @id @default(autoincrement())
  discordChannelId String
  notificationType ChannelNotification @unique

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  @@map("DiscordNotificationChannel")
}

model ExpectedGame {
  id           Int      @id @default(autoincrement())
  igdbId       Int
  name         String   @db.VarChar(255)
  url          String   @db.VarChar(255)
  addToBacklog Boolean
  cancelled    Boolean?
  userId       Int

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  releaseDate ExpectedGameReleaseDate?
  user        User                     @relation(fields: [userId], references: [id])

  @@unique([igdbId, userId])
  @@map("ExpectedGame")
}

model ExpectedGameReleaseDate {
  id             Int       @id @default(autoincrement())
  date           DateTime?
  platformId     Int
  region         Int
  expectedGameId Int       @unique

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  expectedGame ExpectedGame @relation(fields: [expectedGameId], references: [id], onDelete: Cascade)

  @@map("ExpectedGameReleaseDate")
}

model GameCache {
  id      Int  @id @default(autoincrement())
  igdbId  Int  @unique
  content Json

  @@map("GameCache")
}

model GachaGift {
  id                Int      @id @default(autoincrement())
  beginningDatetime DateTime @db.DateTime(0)
  endDatetime       DateTime @db.DateTime(0)
  code              String   @unique @db.VarChar(255)
  bonus             Json

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  players GachaPlayer[]

  @@map("GachaGift")
}

model Pagination {
  id               Int            @id @default(autoincrement())
  page             Int
  discordMessageId String         @unique @db.VarChar(255)
  discordUserId    String         @db.VarChar(255)
  type             PaginationType @default(GACHA_INVENTORY) // to backfill existing

  @@map("Pagination")
}

model GachaPlayer {
  id                 Int       @id @default(autoincrement())
  points             Int
  lastMessageDate    DateTime  @default(now()) @db.DateTime(0)
  lastDailyDraw      DateTime? @db.DateTime(0)
  lastPointsReminder DateTime? @db.DateTime(0)
  wantToBeWarn       Boolean   @default(false)
  joinDate           DateTime  @default(now()) @db.DateTime(0)
  userId             Int       @unique
  finishRank         Int?      @unique

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  gifts                GachaGift[]
  gachaPlayerInventory GachaPlayerInventory[]
  dailyPurchase        GachaDailyPurchase[]
  user                 User                   @relation(fields: [userId], references: [id])

  @@map("GachaPlayer")
}

model GachaPlayerInventory {
  id         Int    @id @default(autoincrement())
  total      Int
  playerId   Int
  cardTypeId Int
  type       String @db.VarChar(255)

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  cardType    CardType    @relation(fields: [cardTypeId], references: [id])
  gachaPlayer GachaPlayer @relation(fields: [playerId], references: [id])

  @@unique([playerId, cardTypeId, type])
  @@index([cardTypeId])
  @@index([playerId])
  @@map("GachaPlayerInventory")
}

model Tag {
  id       Int        @id @default(autoincrement())
  name     String     @unique @db.VarChar(255)
  blogPost BlogPost[]

  @@map("Tag")
}

model User {
  id             Int     @id @default(autoincrement())
  discordId      String  @unique @db.VarChar(255)
  twitchUsername String? @unique @db.VarChar(255)
  username       String  @db.VarChar(255)
  isActive       Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  gachaPlayer     GachaPlayer?
  backlogItems    BacklogItem[]
  expectedGames   ExpectedGame[]
  adventurePlayer AdventurePlayer?

  @@index([discordId])
  @@map("User")
}

model AdventurePlayer {
  id     Int @id @default(autoincrement())
  userId Int @unique

  name       String
  gold       Int    @default(0)
  level      Int    @default(1)
  experience Int    @default(0)
  health     Int
  raidLeft   Int    @default(5)

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  user                User                                @relation(fields: [userId], references: [id])
  raids               AdventureRaid[]
  equipments          AdventurePlayerEquipment[]
  inventoryEquipments AdventurePlayerInventoryEquipment[]

  @@index([userId])
  @@map("AdventurePlayer")
}

model AdventureEquipment {
  id                        Int                    @id @default(autoincrement())
  name                      String
  imageUrl                  String
  level                     Int
  physicalDamageLowerBound  Int
  magicDamageLowerBound     Int
  physicalDamageHigherBound Int
  magicDamageHigherBound    Int
  life                      Int
  shield                    Int
  consummable               Boolean
  rarity                    AdventureRarity
  slot                      AdventureEquipmentType

  createdAt                 DateTime                            @default(now()) @db.Timestamp(3)
  updatedAt                 DateTime                            @default(now()) @updatedAt @db.Timestamp(3)
  rooms                     AdventureRaidRoom[]
  playerEquipments          AdventurePlayerEquipment[]
  playerInventoryEquipments AdventurePlayerInventoryEquipment[]

  @@map("AdventureEquipment")
}

model AdventureEnemy {
  id         Int    @id @default(autoincrement())
  name       String
  imageUrl   String
  difficulty Int    @default(1)

  // in the future : drop resources & craft ?

  physicalDamageMultiplierLowerBound  Float
  magicDamageMultiplierLowerBound     Float
  physicalDamageMultiplierHigherBound Float
  magicDamageMultiplierHigherBound    Float
  lifeMultiplier                      Float
  shieldMultiplier                    Float

  createdAt DateTime            @default(now()) @db.Timestamp(3)
  updatedAt DateTime            @default(now()) @updatedAt @db.Timestamp(3)
  rooms     AdventureRaidRoom[]

  @@map("AdventureEnemy")
}

model AdventurePlayerEquipment {
  id          Int           @id @default(autoincrement())
  playerId    Int
  equipmentId Int
  slot        AdventureSlot

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  player    AdventurePlayer    @relation(fields: [playerId], references: [id])
  equipment AdventureEquipment @relation(fields: [equipmentId], references: [id])

  @@unique([playerId, slot])
  @@index([playerId])
  @@index([equipmentId])
  @@map("AdventurePlayerEquipment")
}

model AdventurePlayerInventoryEquipment {
  id          Int @id @default(autoincrement())
  playerId    Int
  equipmentId Int
  count       Int @default(1)

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  player    AdventurePlayer    @relation(fields: [playerId], references: [id])
  equipment AdventureEquipment @relation(fields: [equipmentId], references: [id])

  @@unique([playerId, equipmentId])
  @@index([playerId])
  @@index([equipmentId])
  @@map("AdventurePlayerInventoryEquipment")
}

model AdventureRaid {
  id       Int    @id @default(autoincrement())
  name     String
  threadId String
  playerId Int

  playerX Int
  playerY Int
  active  Boolean

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  player AdventurePlayer     @relation(fields: [playerId], references: [id])
  rooms  AdventureRaidRoom[]

  @@index([playerId])
  @@index([threadId])
  @@map("AdventureRaid")
}

model AdventureRaidRoom {
  id     Int @id @default(autoincrement())
  raidId Int

  x    Int
  y    Int
  seen Boolean @default(false)

  isEscape       Boolean
  enemyId        Int?
  enemyLevel     Int     @default(1)
  enemyLife      Int     @default(0)
  equipmentId    Int?
  equipmentTaken Boolean @default(false)

  raid      AdventureRaid       @relation(fields: [raidId], references: [id])
  enemy     AdventureEnemy?     @relation(fields: [enemyId], references: [id])
  equipment AdventureEquipment? @relation(fields: [equipmentId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(3)

  @@index([raidId])
  @@index([enemyId])
  @@index([equipmentId])
  @@map("AdventureRaidRoom")
}

//-- Enums

enum BacklogStatus {
  BACKLOG
  CURRENTLY
  FINISHED
  ABANDONED
  WISHLIST
}

enum BlogStatus {
  PUBLISHED
  NOT_PUBLISHED
}

enum Category {
  NEWS
  TECH
  VIDEOGAME
  OTHER
}

enum ChannelNotification {
  BIRTHDAY
  MEME
  SHOP
}

enum AdventureEquipmentType {
  HEAD
  BODY
  ARM
  PANTS
  SHOES
  HAND
  DUAL_HAND
  CONSUMABLE
}

enum AdventureSlot {
  HEAD
  BODY
  ARM_LEFT
  ARM_RIGHT
  PANTS
  SHOES
  HAND_LEFT
  HAND_RIGHT
  CONSUMABLE_1
  CONSUMABLE_2
}

enum AdventureRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum PaginationType {
  GACHA_INVENTORY
  ADVENTURE_INVENTORY
}
